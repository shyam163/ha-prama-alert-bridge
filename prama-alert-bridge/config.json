{
  "name": "Prama Alert Bridge",
  "version": "2.0.0",
  "slug": "prama_alert_bridge",
  "description": "Bridges one or more Prama camera AI human/vehicle detection to Home Assistant via MQTT auto-discovery",
  "arch": ["amd64", "aarch64", "armv7", "armhf", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "timeout": 30,
  "options": {
    "cameras": [
      {
        "host": "",
        "username": "admin",
        "password": "",
        "sensor_name": "prama",
        "detection_types": ["human"],
        "off_delay": 120
      }
    ],
    "mqtt_host": "",
    "mqtt_port": 1883,
    "mqtt_username": "",
    "mqtt_password": "",
    "log_level": "info"
  },
  "schema": {
    "cameras": [
      {
        "host": "str",
        "username": "str",
        "password": "password",
        "sensor_name": "str",
        "detection_types": ["str"],
        "off_delay": "int(10,600)"
      }
    ],
    "mqtt_host": "str",
    "mqtt_port": "port",
    "mqtt_username": "str",
    "mqtt_password": "password",
    "log_level": "list(debug|info|warning|error)"
  },
  "map": ["config:rw"]
}
